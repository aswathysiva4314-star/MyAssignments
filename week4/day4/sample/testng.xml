<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lead Management Suite" verbose="1" thread-count="2"  parallel="tests">

    <test name="Lead Creation Flow" parallel="classes">
        <classes>
            <class name="com.testng.sample.CreateLead"/>
            <class name="com.testng.sample.DuplicateLead"/>
             <class name="com.testng.sample.EditLead"/>
        </classes>
    </test>

    <test name="Lead Deletion Flow" parallel="classes" >
        <classes>
            <class name="com.testng.sample.DeleteLead"/>
        </classes>
    </test>

</suite>



